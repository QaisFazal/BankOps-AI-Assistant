# App
APP_NAME="AI Lead Assistant"
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=http://localhost:8501
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_REFILL_RATE_PER_SECOND=1.0
TOOL_TIMEOUT_SECONDS=5.0

# Model provider
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-lead-assistant

# Pinecone retrieval
RETRIEVAL_BACKEND=local
RETRIEVAL_ALPHA=0.6
PINECONE_API_KEY=
PINECONE_INDEX_NAME=ai-lead-assistant
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=local
# environment uses one namespace, department uses names like local-payments.
PINECONE_NAMESPACE_MODE=environment
PINECONE_SPARSE_DIMENSIONS=100000
